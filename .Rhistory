library(ggplot2)   # visualização de dados
library(dplyr)     # manipulação de dados (já vimos na aula 1!)
library(gapminder) # base de dados
library(forcats)   # função para lidar com dados qualitativos
# Carregando os dados (igual à aula passada!)
dados = gapminder::gapminder
glimpse(dados)
# Filtrando Brasil e Chile (relembrando o filter() da aula 1!) e guardando em um objeto chamado brasil_chile
brasil_chile = dados |>
filter(country %in% c("Brazil", "Chile"))
brasil_chile |>
ggplot(aes(x = year,
y = gdpPercap)) +
geom_line()
brasil_chile |>
ggplot(aes(x = year,
y = gdpPercap,
col = country)) +
geom_line()
brasil_chile |>
ggplot(aes(x = year,
y = gdpPercap,
color = country)) +
geom_line() +
geom_point() +
labs(
title = "Evolução do PIB per capita",
subtitle = "Brasil e Chile | 1952–2007",
x = "Ano",
y = "PIB per capita (US$)",
color = "País",
caption = "Fonte: Gapminder"
)
brasil_chile |>
ggplot(aes(x = year,
y = gdpPercap,
color = country)) +
geom_line(linewidth = 1.2) +
geom_point(size = 2.5) +
labs(
title = "Evolução do PIB per capita",
subtitle = "Brasil e Chile | 1952–2007",
x = "Ano",
y = "PIB per capita (US$)",
color = "País",
caption = "Fonte: Gapminder"
) +
theme_minimal()
dados_2007 = dados |>
filter(year == 2007)
dados_2007 |>
ggplot(aes(x = gdpPercap)) +
geom_histogram()
dados_2007 |>
ggplot(aes(x = gdpPercap)) +
geom_histogram() +
labs(
title = "Distribuição do PIB per capita em 2007",
x = "PIB per capita (dólares)",
y = "Número de países",
caption = "Fonte: Gapminder"
) +
theme_minimal()
dados_2007 |>
ggplot(aes(x = gdpPercap)) +
geom_histogram(bins = 10,
fill = "steelblue",
color = "white") +
labs(
title = "Distribuição do PIB per capita em 2007",
x = "PIB per capita (dólares)",
y = "Número de países",
caption = "Fonte: Gapminder"
) +
theme_minimal()
dados_2007 |>
ggplot(aes(x = continent,
y = lifeExp,
fill = continent)) +
geom_boxplot() +
labs(
title = "Expectativa de Vida por Continente em 2007",
x = "Continente",
y = "Expectativa de vida (anos)",
fill = "Continente",
caption = "Fonte: Gapminder"
) +
theme_minimal() +
ylim(0, 100) +
theme(legend.position = "none") # tira a legenda (já está no eixo X)
dados_2007 |>
ggplot(aes(x = gdpPercap,
fill = continent)) +
geom_histogram(bins = 12,
color = "white") +
labs(
title = "Distribuição do PIB per capita por Continente em 2007",
x = "PIB per capita (dólares)",
y = "Número de países",
fill = "Continente",
caption = "Fonte: Gapminder"
) +
theme_minimal() +
theme(
legend.position = "none",
axis.text.x = element_text(angle = 45, hjust = 1)
)
dados_2007 |>
ggplot(aes(x = gdpPercap,
fill = continent)) +
geom_histogram(bins = 12,
color = "white") +
facet_wrap(~continent) +
labs(
title = "Distribuição do PIB per capita por Continente em 2007",
x = "PIB per capita (dólares)",
y = "Número de países",
fill = "Continente",
caption = "Fonte: Gapminder"
) +
theme_minimal() +
theme(
legend.position = "none",
axis.text.x = element_text(angle = 45, hjust = 1)
)
