library(ggplot2)   # visualização de dados
library(dplyr)     # manipulação de dados (já vimos na aula 1!)
library(gapminder) # base de dados
library(forcats)   # função para lidar com dados qualitativos
library(vroom)     # leitura rápida de dados
library(janitor)   # limpeza de dados
# Carregando os dados (igual à aula passada!)
dados = gapminder::gapminder
glimpse(dados)
nascimentos_tratado =
nascimentos_ano |>
left_join(municipios,
by = c("CODMUNRES"="cod_municipio")) |>
select(ANO, CODMUNRES, uf_sigla, municipio,
total) |>
clean_names()
nascimentos_tratado =
nascimentos_ano |>
left_join(municipios,
by = c("CODMUNRES"="cod_municipio")) |>
select(ANO, CODMUNRES, uf_sigla, municipio,
total) |>
clean_names()
glimpse(nascimentos_tratado)
nascimentos_tratado =
nascimentos_ano |>
left_join(municipios,
by = c("CODMUNRES"="cod_municipio")) |>
select(ANO, CODMUNRES, uf_sigla, municipio,
total) |>
clean_names()
nascimentos_tratado
View(nascimentos_tratado)
